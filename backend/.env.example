# GemVault backend — environment variables
# Copy to .env and fill in. NEVER commit .env.

# --- Application ---
APP_ENV=development                # development | staging | production
LOG_LEVEL=INFO

# --- Database ---
DATABASE_URL=postgresql+asyncpg://gemvault:gemvault@localhost:5432/gemvault

# --- Auth (stub JWT — ADR-004) ---
JWT_SECRET=replace-with-32-byte-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_SECONDS=3600

# --- Chain ---
BASE_RPC_URL=https://sepolia.base.org
BASE_CHAIN_ID=84532
CERTIFICATE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
ADMIN_PRIVATE_KEY=replace-with-base-sepolia-test-key
USDC_CONTRACT_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e   # Base Sepolia USDC

# --- IPFS (Pinata) ---
PINATA_JWT=replace-with-pinata-jwt
IPFS_GATEWAY_URL=https://gateway.pinata.cloud/ipfs

# --- Vault HMAC ---
VAULT_HMAC_SECRETS=zurich-001:replace-with-32-byte-secret,paris-002:another-32-byte-secret

# --- Basescan ---
BASESCAN_API_KEY=replace-with-basescan-key
